@page "/pricing"
@using VatBe.Stripe
@inject ICheckoutService CheckoutService
@inject IOptions<StripeSettings> StripeOptions
@inject NavigationManager Nav
@using Microsoft.Extensions.Options

<PageTitle>VatBe — Pricing</PageTitle>

<div class="hero">
    <div class="hero-icon">💳</div>
    <h1 class="hero-title">Simple, transparent <span class="accent">pricing</span></h1>
    <p class="hero-subtitle">
        Start free. Upgrade when you need bulk lookups, webhooks, or commercial use.
    </p>
</div>

<div class="billing-toggle">
    <button class="@BillingClass(false)" @onclick="() => Annual = false">Monthly</button>
    <button class="@BillingClass(true)"  @onclick="() => Annual = true">Annual <span class="badge-save">Save 20%</span></button>
</div>

<div class="pricing-grid">

    <!-- Free -->
    <div class="pricing-card">
        <div class="plan-name">Free</div>
        <div class="plan-price">€0 <span class="plan-period">/ month</span></div>
        <div class="plan-desc">Open-source, self-hosted. Perfect for personal projects and evaluation.</div>
        <ul class="plan-features">
            <li>✅ KBO/BCE validation</li>
            <li>✅ VIES EU lookups</li>
            <li>✅ VAT calculator</li>
            <li>✅ .NET NuGet library</li>
            <li>✅ MIT licensed</li>
            <li>❌ API access</li>
            <li>❌ Bulk processing</li>
            <li>❌ Webhooks</li>
        </ul>
        <a class="btn-plan btn-outline" href="https://github.com/phmatray/VatBe" target="_blank">View on GitHub</a>
    </div>

    <!-- Pro -->
    <div class="pricing-card featured">
        <div class="plan-badge">Most Popular</div>
        <div class="plan-name">Pro</div>
        <div class="plan-price">@(Annual ? "€12" : "€15") <span class="plan-period">/ month</span></div>
        @if (Annual)
        {
            <div class="plan-annual-note">Billed €144 / year</div>
        }
        <div class="plan-desc">For developers and small businesses that need reliable Belgian VAT infrastructure.</div>
        <ul class="plan-features">
            <li>✅ Everything in Free</li>
            <li>✅ REST API access</li>
            <li>✅ 10,000 lookups / month</li>
            <li>✅ Webhook events</li>
            <li>✅ API key management</li>
            <li>✅ Email support</li>
            <li>❌ Custom SLA</li>
            <li>❌ Dedicated instance</li>
        </ul>
        <button class="btn-plan btn-primary" @onclick="() => StartCheckout(PlanTier.Pro)" disabled="@IsCheckingOut">
            @if (IsCheckingOut && CheckingOutTier == PlanTier.Pro)
            { <span class="spinner"></span> }
            else
            { <span>Get Started</span> }
        </button>
    </div>

    <!-- Enterprise -->
    <div class="pricing-card">
        <div class="plan-name">Enterprise</div>
        <div class="plan-price">@(Annual ? "€79" : "€99") <span class="plan-period">/ month</span></div>
        @if (Annual)
        {
            <div class="plan-annual-note">Billed €948 / year</div>
        }
        <div class="plan-desc">For companies processing high volumes or needing guaranteed uptime and compliance.</div>
        <ul class="plan-features">
            <li>✅ Everything in Pro</li>
            <li>✅ Unlimited lookups</li>
            <li>✅ Dedicated instance</li>
            <li>✅ 99.9% SLA</li>
            <li>✅ Priority support</li>
            <li>✅ Custom billing period</li>
            <li>✅ Invoice with Belgian VAT</li>
            <li>✅ GDPR DPA on request</li>
        </ul>
        <button class="btn-plan btn-secondary" @onclick="() => StartCheckout(PlanTier.Enterprise)" disabled="@IsCheckingOut">
            @if (IsCheckingOut && CheckingOutTier == PlanTier.Enterprise)
            { <span class="spinner"></span> }
            else
            { <span>Get Started</span> }
        </button>
    </div>

</div>

@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="checkout-error">⚠️ @ErrorMessage</div>
}

<div class="pricing-faq">
    <h2>FAQ</h2>
    <details>
        <summary>Do I need a credit card for the Free plan?</summary>
        <p>No. The Free tier is just the open-source library — no account needed.</p>
    </details>
    <details>
        <summary>Can I cancel anytime?</summary>
        <p>Yes. Subscriptions are monthly (or annual). Cancel from your billing portal at any time — no lock-in.</p>
    </details>
    <details>
        <summary>Do you issue Belgian VAT invoices?</summary>
        <p>Yes. Enterprise invoices include Belgian VAT (BE 21%) by default. Pro invoices on request.</p>
    </details>
    <details>
        <summary>Is the API GDPR-compliant?</summary>
        <p>Yes. Data is processed within the EU. A GDPR Data Processing Agreement (DPA) is available for Enterprise customers.</p>
    </details>
</div>

@code {
    private enum PlanTier { Pro, Enterprise }

    private bool Annual = false;
    private bool IsCheckingOut = false;
    private PlanTier? CheckingOutTier = null;
    private string? ErrorMessage = null;

    private string BillingClass(bool annual) => annual == Annual ? "billing-btn active" : "billing-btn";

    private async Task StartCheckout(PlanTier tier)
    {
        ErrorMessage = null;
        IsCheckingOut = true;
        CheckingOutTier = tier;
        StateHasChanged();

        try
        {
            var prices = StripeOptions.Value.Prices;
            var priceId = (tier, Annual) switch
            {
                (PlanTier.Pro, false)        => prices.ProMonthly,
                (PlanTier.Pro, true)         => prices.ProAnnual,
                (PlanTier.Enterprise, false) => prices.EnterpriseMonthly,
                (PlanTier.Enterprise, true)  => prices.EnterpriseAnnual,
                _                            => throw new InvalidOperationException("Unknown plan tier")
            };

            if (string.IsNullOrWhiteSpace(priceId))
            {
                ErrorMessage = "This plan is not yet available. Please check back soon.";
                return;
            }

            var checkoutUrl = await CheckoutService.CreateSessionUrlAsync(priceId);
            Nav.NavigateTo(checkoutUrl, forceLoad: true);
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Could not initiate checkout: {ex.Message}";
        }
        finally
        {
            IsCheckingOut = false;
            CheckingOutTier = null;
        }
    }
}
