@page "/checkout/success"
@using Microsoft.AspNetCore.WebUtilities

<PageTitle>VatBe — Subscription Confirmed</PageTitle>

<div class="hero">
    <div class="hero-icon">🎉</div>
    <h1 class="hero-title">You're all set!</h1>
    <p class="hero-subtitle">
        Your VatBe subscription is now active. Check your inbox for a confirmation email with your API key.
    </p>
</div>

<div class="checker-card" style="text-align:center">
    <p>Session ID: <code>@SessionId</code></p>
    <p style="margin-top:1rem">
        <a class="btn-check" href="/">← Back to Checker</a>
    </p>
</div>

@code {
    [SupplyParameterFromQuery(Name = "session_id")]
    public string? SessionId { get; set; }
}
